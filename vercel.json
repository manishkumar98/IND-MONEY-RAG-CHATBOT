{
    "version": 2,
    "builds": [
        {
            "src": "src/api/api.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/**",
            "use": "@vercel/static"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "src/api/api.py"
        },
        {
            "source": "/",
            "destination": "frontend/index.html"
        },
        {
            "source": "/style.css",
            "destination": "frontend/style.css"
        },
        {
            "source": "/app.js",
            "destination": "frontend/app.js"
        }
    ]
}